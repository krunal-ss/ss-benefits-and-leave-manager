# ---- Database (Supabase Postgres, used by Drizzle) ----
# Use the pooled connection string for the app; direct for migrations.
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ---- Supabase Auth / Storage ----
# Receipt uploads (KAN-41) go to a PRIVATE storage bucket named "receipts" —
# create it in the Supabase dashboard (Storage → New bucket, Public = OFF).
# SUPABASE_SERVICE_ROLE_KEY is required server-side to write/sign private objects.
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server-only; never expose

# ---- Email (Resend) ----
RESEND_API_KEY="re_..."
EMAIL_FROM="SmartSense <no-reply@smartsense.example>"

# ---- Receipt OCR / parsing (Claude API) ----
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Scheduled jobs (Vercel Cron) ----
# Authenticates the daily capacity-snapshot job (KAN-79, vercel.json) — Vercel
# sends this automatically as `Authorization: Bearer $CRON_SECRET` for that cron.
CRON_SECRET="a-long-random-secret"
